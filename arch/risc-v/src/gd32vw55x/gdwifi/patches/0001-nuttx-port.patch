--- a/MSDK/plf/riscv/gd32vw55x/gd32vw55x.h
+++ b/MSDK/plf/riscv/gd32vw55x/gd32vw55x.h
@@ -248,7 +248,17 @@ typedef enum EXCn {
 /* enum definitions */
 typedef enum {DISABLE = 0, ENABLE = !DISABLE} EventStatus, ControlStatus;
 typedef enum {RESET = 0, SET = !RESET} FlagStatus;
+#ifdef GDWIFI_NUTTX
+/* port NuttX: NuttX <sys/types.h> ja define o enumerador ERROR; macros
+ * preservam a semantica da SPL (ERROR==0, SUCCESS==1) sem colidir. */
+typedef int ErrStatus;
+#undef ERROR
+#undef SUCCESS
+#define ERROR   0
+#define SUCCESS 1
+#else
 typedef enum {ERROR = 0, SUCCESS = !ERROR} ErrStatus;
+#endif
 
 /* bit operations */
 #define REG32(addr)                  (*(volatile uint32_t *)(uint32_t)(addr))
